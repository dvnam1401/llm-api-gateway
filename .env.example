# Groq API keys — each key on its own env var, prefixed with GROQ_API_KEY_
# Priority order = alphabetical sort of the suffix
GROQ_API_KEY_acc01=gsk_key1
GROQ_API_KEY_acc02=gsk_key2
GROQ_API_KEY_acc03=gsk_key3
GROQ_API_KEY_acc04=gsk_key4
GROQ_API_KEY_acc05=gsk_key5

# Secret key chatbot uses to authenticate with the gateway (Bearer token)
GATEWAY_SECRET=some_random_secret_string

# Redis URL (Render Redis add-on or external)
REDIS_URL=redis://localhost:6379

# Timeout per request forwarded to Groq (seconds)
REQUEST_TIMEOUT=60

# Consecutive errors before circuit breaker trips
CIRCUIT_BREAKER_THRESHOLD=3

# Duration circuit breaker keeps key in OPEN state (seconds)
CIRCUIT_BREAKER_COOLDOWN=300
